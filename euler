<!DOCTYPE html>

<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>오일러 공식 시각화</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: #0F1B3C;
    color: #f5f5f5;
    min-height: 100vh;
    padding: 20px 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  h1 {
    color: #E8B43A;
    font-size: 1.4rem;
    margin-bottom: 4px;
    text-align: center;
  }
  .subtitle {
    font-size: 0.85rem;
    opacity: 0.7;
    margin-bottom: 20px;
    text-align: center;
  }
  .canvas-wrap {
    width: 100%;
    max-width: 360px;
    aspect-ratio: 1;
    background: #fff;
    border-radius: 12px;
    margin-bottom: 16px;
    position: relative;
    overflow: hidden;
  }
  canvas { width: 100%; height: 100%; display: block; }
  .formula {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(232,180,58,0.3);
    border-radius: 10px;
    padding: 14px 16px;
    width: 100%;
    max-width: 360px;
    font-family: 'Times New Roman', serif;
    font-size: 1.1rem;
    text-align: center;
    margin-bottom: 16px;
    line-height: 1.6;
  }
  .formula .yellow { color: #E8B43A; font-weight: bold; }
  .controls {
    width: 100%;
    max-width: 360px;
    background: rgba(255,255,255,0.06);
    border-radius: 10px;
    padding: 16px;
  }
  .slider-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }
  .slider-label { font-size: 0.85rem; min-width: 60px; }
  input[type="range"] {
    flex: 1;
    accent-color: #E8B43A;
  }
  .angle-display {
    font-family: 'Courier New', monospace;
    font-size: 0.85rem;
    color: #E8B43A;
    min-width: 70px;
    text-align: right;
  }
  .preset-row {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }
  .preset-btn {
    flex: 1;
    min-width: 60px;
    background: rgba(232,180,58,0.15);
    color: #E8B43A;
    border: 1px solid rgba(232,180,58,0.4);
    border-radius: 6px;
    padding: 8px 4px;
    font-size: 0.8rem;
    cursor: pointer;
    font-family: inherit;
  }
  .preset-btn:active { background: rgba(232,180,58,0.3); }
  .play-btn {
    width: 100%;
    background: #E8B43A;
    color: #0F1B3C;
    border: none;
    border-radius: 6px;
    padding: 10px;
    font-size: 0.9rem;
    font-weight: bold;
    cursor: pointer;
    font-family: inherit;
  }
  .play-btn:active { opacity: 0.8; }
  .note {
    font-size: 0.78rem;
    opacity: 0.65;
    text-align: center;
    margin-top: 14px;
    max-width: 360px;
    line-height: 1.5;
  }
</style>
</head>
<body>
  <h1>오일러 공식</h1>
  <div class="subtitle">슬라이더를 움직여 점이 도는 모습을 보세요</div>

  <div class="canvas-wrap">
    <canvas id="canvas" width="720" height="720"></canvas>
  </div>

  <div class="formula">
    e<sup>i·<span class="yellow" id="angle-text">0.00</span></sup> = 
    <span class="yellow" id="cos-val">1.00</span> + 
    <span class="yellow" id="sin-val">0.00</span>·i
  </div>

  <div class="controls">
    <div class="slider-row">
      <span class="slider-label">각도 x</span>
      <input type="range" id="slider" min="0" max="628" value="0">
      <span class="angle-display" id="angle-display">0°</span>
    </div>

```
<div class="preset-row">
  <button class="preset-btn" data-val="0">0</button>
  <button class="preset-btn" data-val="157">π/2</button>
  <button class="preset-btn" data-val="314">π</button>
  <button class="preset-btn" data-val="471">3π/2</button>
  <button class="preset-btn" data-val="628">2π</button>
</div>

<button class="play-btn" id="play-btn">▶ 자동 회전</button>
```

  </div>

  <div class="note">
    💡 x = π (180°) 일 때 점이 정확히 -1에 닿습니다.<br>
    이게 바로 e<sup>iπ</sup> = -1 이에요.
  </div>

<script>
const canvas = document.getElementById('canvas');
const ctx = canvas.getContext('2d');
const slider = document.getElementById('slider');
const playBtn = document.getElementById('play-btn');
const angleText = document.getElementById('angle-text');
const cosVal = document.getElementById('cos-val');
const sinVal = document.getElementById('sin-val');
const angleDisplay = document.getElementById('angle-display');

const W = canvas.width, H = canvas.height;
const cx = W / 2, cy = H / 2;
const R = 240;

let isPlaying = false;
let animFrame = null;

function draw(xVal) {
  // x is from 0 to 6.28 (2π)
  const x = xVal / 100;
  const cosX = Math.cos(x);
  const sinX = Math.sin(x);
  
  ctx.clearRect(0, 0, W, H);
  
  // Background grid
  ctx.strokeStyle = '#e8e8e8';
  ctx.lineWidth = 1;
  for (let i = -3; i <= 3; i++) {
    if (i === 0) continue;
    ctx.beginPath();
    ctx.moveTo(cx + i * R / 1.5, 0);
    ctx.lineTo(cx + i * R / 1.5, H);
    ctx.stroke();
    ctx.beginPath();
    ctx.moveTo(0, cy + i * R / 1.5);
    ctx.lineTo(W, cy + i * R / 1.5);
    ctx.stroke();
  }
  
  // Axes
  ctx.strokeStyle = '#666';
  ctx.lineWidth = 2;
  ctx.beginPath();
  ctx.moveTo(0, cy); ctx.lineTo(W, cy);
  ctx.moveTo(cx, 0); ctx.lineTo(cx, H);
  ctx.stroke();
  
  // Axis labels
  ctx.fillStyle = '#666';
  ctx.font = 'bold 22px sans-serif';
  ctx.fillText('실수축 (cos)', W - 130, cy - 10);
  ctx.fillText('허수축 (sin·i)', cx + 12, 28);
  
  // Tick marks for ±1
  ctx.fillStyle = '#999';
  ctx.font = '20px sans-serif';
  ctx.fillText('1', cx + R + 8, cy + 22);
  ctx.fillText('-1', cx - R - 28, cy + 22);
  ctx.fillText('i', cx + 8, cy - R - 4);
  ctx.fillText('-i', cx + 8, cy + R + 22);
  
  // Unit circle
  ctx.strokeStyle = '#0F1B3C';
  ctx.lineWidth = 2;
  ctx.beginPath();
  ctx.arc(cx, cy, R, 0, Math.PI * 2);
  ctx.stroke();
  
  // Trail (path traveled so far)
  ctx.strokeStyle = '#E8B43A';
  ctx.lineWidth = 4;
  ctx.beginPath();
  ctx.arc(cx, cy, R, 0, -x, true);
  ctx.stroke();
  
  // Point position
  const px = cx + R * cosX;
  const py = cy - R * sinX;
  
  // Radius line from origin to point
  ctx.strokeStyle = '#0F1B3C';
  ctx.lineWidth = 2;
  ctx.setLineDash([6, 4]);
  ctx.beginPath();
  ctx.moveTo(cx, cy);
  ctx.lineTo(px, py);
  ctx.stroke();
  ctx.setLineDash([]);
  
  // Projection lines (showing cos and sin components)
  ctx.strokeStyle = '#999';
  ctx.lineWidth = 1.5;
  ctx.setLineDash([3, 3]);
  ctx.beginPath();
  ctx.moveTo(px, py);
  ctx.lineTo(px, cy);
  ctx.moveTo(px, py);
  ctx.lineTo(cx, py);
  ctx.stroke();
  ctx.setLineDash([]);
  
  // Point itself
  ctx.fillStyle = '#E8B43A';
  ctx.strokeStyle = '#0F1B3C';
  ctx.lineWidth = 3;
  ctx.beginPath();
  ctx.arc(px, py, 12, 0, Math.PI * 2);
  ctx.fill();
  ctx.stroke();
  
  // Origin point
  ctx.fillStyle = '#0F1B3C';
  ctx.beginPath();
  ctx.arc(cx, cy, 5, 0, Math.PI * 2);
  ctx.fill();
  
  // Update text
  angleText.textContent = x.toFixed(2);
  cosVal.textContent = cosX.toFixed(2);
  sinVal.textContent = sinX.toFixed(2);
  const deg = Math.round(x * 180 / Math.PI);
  angleDisplay.textContent = deg + '°';
}

slider.addEventListener('input', (e) => {
  if (isPlaying) togglePlay();
  draw(parseInt(e.target.value));
});

document.querySelectorAll('.preset-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    if (isPlaying) togglePlay();
    const val = parseInt(btn.dataset.val);
    slider.value = val;
    draw(val);
  });
});

function togglePlay() {
  isPlaying = !isPlaying;
  playBtn.textContent = isPlaying ? '⏸ 일시정지' : '▶ 자동 회전';
  if (isPlaying) animate();
  else if (animFrame) cancelAnimationFrame(animFrame);
}

function animate() {
  let val = parseInt(slider.value);
  val = (val + 2) % 629;
  slider.value = val;
  draw(val);
  if (isPlaying) animFrame = requestAnimationFrame(animate);
}

playBtn.addEventListener('click', togglePlay);

// Initial draw
draw(0);
</script>

</body>
</html>
